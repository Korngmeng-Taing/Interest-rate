        "---\n",
        "\n",
        "## Bond Price Analysis\n",
        "\n",
        "### Key Observations"
      ],
      "id": "7bf8e5a1"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| code-fold: true\n",
        "#| code-summary: \"Bond price analysis\"\n",
        "\n",
        "import numpy as np\n",
        "\n",
        "# Extract prices\n",
        "prices = price_table['Price'].values\n",
        "maturities = price_table['Maturity (years)'].values\n",
        "\n",
        "print(\"\\nBond Price Analysis:\")\n",
        "print(\"-\" * 60)\n",
        "\n",
        "# Compare prices\n",
        "for i in range(len(prices) - 1):\n",
        "    change_percentage = (prices[i+1] - prices[i]) / prices[i] * 100\n",
        "    print(f\"  {maturities[i]:.0f}Y vs {maturities[i+1]:.0f}Y: \"\n",
        "          f\"${prices[i]:.4f} → ${prices[i+1]:.4f} \"\n",
        "          f\"({change_percentage:+.2f}%)\")\n",
        "\n",
        "# Duration approximation\n",
        "duration = -(prices[2] - prices[1]) / (prices[1] * 0.01 / maturities[1])\n",
        "print(f\"\\nApproximate Duration (at 5Y): {duration:.2f} years\")\n",
        "\n",
        "print(\"\\nInterpretation:\")\n",
        "print(\"✓ Longer maturity → Lower price (more discounting)\")\n",
        "print(\"✓ Price decay is non-linear (convex)\")\n",
        "print(\"✓ Stochastic rates add uncertainty (wider CI for longer bonds)\")"
      ],
      "id": "fe10cecc",
      "execution_count": null,
      "outputs": []
    },
