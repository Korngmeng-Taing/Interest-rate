        "---\n",
        "\n",
        "## Portfolio Pricing Example\n",
        "\n",
        "### Portfolio Construction\n",
        "\n",
        "Let's price a portfolio with three bonds:"
      ],
      "id": "36294e9c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: portfolio-pricing\n",
        "#| code-fold: true\n",
        "#| code-summary: Price a bond portfolio\n",
        "\n",
        "# Define portfolio\n",
        "bonds_portfolio = {\n",
        "    'Bond A (2Y)': (2, 0.30),   # 2-year bond, 30% weight\n",
        "    'Bond B (5Y)': (5, 0.40),   # 5-year bond, 40% weight\n",
        "    'Bond C (10Y)': (10, 0.30)  # 10-year bond, 30% weight\n",
        "}\n",
        "\n",
        "# Use pricer from above\n",
        "portfolio_results = pricer.price_portfolio(paths, bonds_portfolio)\n",
        "\n",
        "# Display results\n",
        "print(\"\\n\" + \"=\" * 80)\n",
        "print(\"BOND PORTFOLIO PRICING\")\n",
        "print(\"=\" * 80)\n",
        "\n",
        "# Individual bonds\n",
        "for name, result in list(portfolio_results.items())[:-1]:\n",
        "    print(f\"\\n{name}:\")\n",
        "    print(f\"  Price:       ${result['price']:.4f}\")\n",
        "    print(f\"  Weight:      {result['weight']:.1%}\")\n",
        "    print(f\"  Contribution: ${result['weighted_price']:.4f}\")\n",
        "    print(f\"  Std Error:   ${result['std_error']:.6f}\")\n",
        "\n",
        "# Portfolio\n",
        "portfolio = portfolio_results['Portfolio']\n",
        "print(f\"\\n{'Portfolio Aggregate':-^80}\")\n",
        "print(f\"  Total Value:  ${portfolio['price']:.4f}\")\n",
        "print(f\"  Weights Sum:  {portfolio['weights']:.1%}\")\n",
        "\n",
        "# Visualization\n",
        "bond_names = [name for name in portfolio_results.keys() if name != 'Portfolio']\n",
        "prices = [portfolio_results[name]['price'] for name in bond_names]\n",
        "weights = [portfolio_results[name]['weight'] for name in bond_names]\n",
        "contributions = [portfolio_results[name]['weighted_price'] for name in bond_names]\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 6))\n",
        "\n",
        "# Left: Individual bond prices\n",
        "colors = ['#1f77b4', '#ff7f0e', '#2ca02c']\n",
        "axes[0].bar(range(len(bond_names)), prices, color=colors, alpha=0.7, edgecolor='black', linewidth=1.5)\n",
        "axes[0].axhline(y=1.0, color='red', linestyle='--', alpha=0.5, linewidth=2)\n",
        "axes[0].set_ylabel('Bond Price', fontsize=12, fontweight='bold')\n",
        "axes[0].set_title('Individual Bond Prices', fontsize=13, fontweight='bold')\n",
        "axes[0].set_xticks(range(len(bond_names)))\n",
        "axes[0].set_xticklabels(bond_names, fontsize=10)\n",
        "axes[0].set_ylim([0.6, 1.05])\n",
        "axes[0].grid(True, alpha=0.3, axis='y')\n",
        "\n",
        "# Add value labels\n",
        "for i, (name, price) in enumerate(zip(bond_names, prices)):\n",
        "    axes[0].text(i, price + 0.01, f'${price:.4f}', ha='center', fontsize=10, fontweight='bold')\n",
        "\n",
        "# Right: Contribution to portfolio value\n",
        "axes[1].pie(contributions, labels=bond_names, autopct='%1.1f%%', colors=colors,\n",
        "            startangle=90, textprops={'fontsize': 11, 'fontweight': 'bold'})\n",
        "axes[1].set_title('Portfolio Value Composition', fontsize=13, fontweight='bold')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
