        "---\n",
        "\n",
        "## Sensitivity to Parameters\n",
        "\n",
        "### Effect of Initial Rate\n",
        "\n",
        "Price bonds under different starting rates:"
      ],
      "id": "92bb5e6b"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| code-fold: true\n",
        "#| code-summary: \"Sensitivity to initial rate\"\n",
        "\n",
        "# Simulate under different initial rates\n",
        "initial_rates = [0.02, 0.03, 0.05]\n",
        "results_by_r0 = {}\n",
        "\n",
        "for r0_val in initial_rates:\n",
        "    sim = DothanSimulator(r0=r0_val, mu=0.02, sigma=0.15, T=10, dt=0.01)\n",
        "    paths_r0 = sim.simulate_paths(n_paths=5000, seed=42)\n",
        "    \n",
        "    maturities_test = [1, 3, 5, 10]\n",
        "    prices_r0 = []\n",
        "    for T in maturities_test:\n",
        "        result = pricer.price_from_paths(paths_r0, T)\n",
        "        prices_r0.append(result['price'])\n",
        "    \n",
        "    results_by_r0[r0_val] = prices_r0\n",
        "\n",
        "# Visualization\n",
        "fig, ax = plt.subplots(figsize=(11, 6))\n",
        "maturities_test = [1, 3, 5, 10]\n",
        "\n",
        "for r0_val, prices in results_by_r0.items():\n",
        "    ax.plot(maturities_test, prices, 'o-', linewidth=2.5, markersize=8,\n",
        "            label=f'r₀ = {r0_val:.1%}')\n",
        "\n",
        "ax.axhline(y=1.0, color='red', linestyle='--', alpha=0.5, linewidth=1.5)\n",
        "ax.set_xlabel('Bond Maturity (years)', fontsize=12, fontweight='bold')\n",
        "ax.set_ylabel('Bond Price', fontsize=12, fontweight='bold')\n",
        "ax.set_title('Bond Prices Under Different Initial Rates\\n(μ=2%, σ=15%)',\n",
        "             fontsize=13, fontweight='bold')\n",
        "ax.legend(fontsize=11, loc='best')\n",
        "ax.grid(True, alpha=0.3)\n",
        "ax.set_ylim([0.60, 1.05])\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\\nEffect of Initial Rate on Bond Prices:\")\n",
        "print(\"-\" * 60)\n",
        "for r0_val in initial_rates:\n",
        "    print(f\"\\nr₀ = {r0_val:.1%}:\")\n",
        "    for T, price in zip(maturities_test, results_by_r0[r0_val]):\n",
        "        print(f\"  {T:2d}Y bond: ${price:.4f}\")"
      ],
