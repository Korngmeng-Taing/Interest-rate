    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Effect of Volatility\n",
        "\n",
        "Price bonds under different volatility levels:"
      ],
      "id": "8f13dad3"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| code-fold: true\n",
        "#| code-summary: \"Sensitivity to volatility\"\n",
        "\n",
        "# Simulate under different volatilities\n",
        "volatilities = [0.10, 0.15, 0.20, 0.30]\n",
        "results_by_sigma = {}\n",
        "\n",
        "for sigma_val in volatilities:\n",
        "    sim = DothanSimulator(r0=0.03, mu=0.02, sigma=sigma_val, T=10, dt=0.01)\n",
        "    paths_sigma = sim.simulate_paths(n_paths=5000, seed=42)\n",
        "    \n",
        "    prices_sigma = []\n",
        "    for T in maturities_test:\n",
        "        result = pricer.price_from_paths(paths_sigma, T)\n",
        "        prices_sigma.append(result['price'])\n",
        "    \n",
        "    results_by_sigma[sigma_val] = prices_sigma\n",
        "\n",
        "# Visualization\n",
        "fig, ax = plt.subplots(figsize=(11, 6))\n",
        "\n",
        "for sigma_val, prices in results_by_sigma.items():\n",
        "    ax.plot(maturities_test, prices, 'o-', linewidth=2.5, markersize=8,\n",
        "            label=f'σ = {sigma_val:.2f}')\n",
        "\n",
        "ax.axhline(y=1.0, color='red', linestyle='--', alpha=0.5, linewidth=1.5)\n",
        "ax.set_xlabel('Bond Maturity (years)', fontsize=12, fontweight='bold')\n",
        "ax.set_ylabel('Bond Price', fontsize=12, fontweight='bold')\n",
        "ax.set_title('Bond Prices Under Different Volatilities\\n(r₀=3%, μ=2%)',\n",
        "             fontsize=13, fontweight='bold')\n",
        "ax.legend(fontsize=11, loc='best')\n",
        "ax.grid(True, alpha=0.3)\n",
        "ax.set_ylim([0.60, 1.05])\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\\nEffect of Volatility on Bond Prices:\")\n",
        "print(\"-\" * 60)\n",
        "for sigma_val in volatilities:\n",
        "    print(f\"\\nσ = {sigma_val:.2f}:\")\n",
        "    for T, price in zip(maturities_test, results_by_sigma[sigma_val]):\n",
        "        print(f\"  {T:2d}Y bond: ${price:.4f}\")\n",
        "        \n",
        "# Calculate convexity premium (higher volatility → higher prices)\n",
        "print(\"\\nConvexity Premium from Volatility:\")\n",
        "print(\"-\" * 60)\n",
        "base_prices = {T: results_by_sigma[0.10][i] for i, T in enumerate(maturities_test)}\n",
        "for sigma_val in [0.15, 0.20, 0.30]:\n",
        "    print(f\"\\nσ = {sigma_val:.2f} vs σ = 0.10:\")\n",
        "    for i, T in enumerate(maturities_test):\n",
        "        premium = (results_by_sigma[sigma_val][i] - base_prices[T]) / base_prices[T] * 100\n",
        "        print(f\"  {T:2d}Y: {premium:+.2f}% premium\")"
      ],
      "id": "9de4977b",
      "execution_count": null,
      "outputs": []
    },
