      "source": [
        "#| code-fold: true\n",
        "#| code-summary: \"Interactive interest rate paths\"\n",
        "\n",
        "# Create interactive plot with Plotly\n",
        "fig = go.Figure()\n",
        "\n",
        "# Add sample paths\n",
        "for i in np.random.choice(paths_vis.shape[1], 50, replace=False):\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=simulator.time_grid, y=paths_vis[:, i],\n",
        "        mode='lines', name=f'Path {i}', \n",
        "        line=dict(color='rgba(25, 25, 112, 0.15)', width=0.5),\n",
        "        hoverinfo='skip', showlegend=False\n",
        "    ))\n",
        "\n",
        "# Add mean\n",
        "fig.add_trace(go.Scatter(\n",
        "    x=simulator.time_grid, y=stats_vis['mean_path'],\n",
        "    mode='lines', name='Mean',\n",
        "    line=dict(color='red', width=3),\n",
        "    hovertemplate='<b>Mean</b><br>Time: %{x:.2f}Y<br>Rate: %{y:.4f}<extra></extra>'\n",
        "))\n",
        "\n",
        "# Add confidence band\n",
        "fig.add_trace(go.Scatter(\n",
        "    x=simulator.time_grid, y=stats_vis['percentile_95'],\n",
        "    mode='lines', name='95th Percentile',\n",
        "    line=dict(color='rgba(255,0,0,0)'),\n",
        "    hovertemplate='<b>95th Percentile</b><br>Time: %{x:.2f}Y<br>Rate: %{y:.4f}<extra></extra>',\n",
        "    showlegend=False\n",
        "))\n",
        "\n",
        "fig.add_trace(go.Scatter(\n",
        "    x=simulator.time_grid, y=stats_vis['percentile_05'],\n",
        "    mode='lines', name='5th Percentile',\n",
        "    line=dict(color='rgba(255,0,0,0)'),\n",
        "    fill='tonexty',\n",
        "    fillcolor='rgba(255,0,0,0.1)',\n",
        "    hovertemplate='<b>5th Percentile</b><br>Time: %{x:.2f}Y<br>Rate: %{y:.4f}<extra></extra>',\n",
        "    showlegend=False\n",
        "))\n",
        "\n",
        "fig.update_layout(\n",
