        "    xaxis_title='Time (years)',\n",
        "    yaxis_title='Interest Rate',\n",
        "    hovermode='x unified',\n",
        "    template='plotly_white',\n",
        "    height=600,\n",
        "    width=1100,\n",
        "    font=dict(size=11),\n",
        ")\n",
        "\n",
        "fig.show()"
      ],
