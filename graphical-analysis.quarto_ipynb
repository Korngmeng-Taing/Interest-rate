        "---\n",
        "\n",
        "## 3. Final Rate Distributions\n",
        "\n",
        "### Histogram with Theoretical Overlay"
      ],
      "id": "0649931a"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| code-fold: true\n",
        "#| code-summary: \"Distribution of final interest rates\"\n",
        "\n",
        "from scipy import stats as scipy_stats\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "axes = axes.flatten()\n",
        "\n",
        "# Different volatility levels\n",
        "volatility_levels = [0.10, 0.15, 0.20, 0.30]\n",
        "\n",
        "for idx, sigma in enumerate(volatility_levels):\n",
        "    sim = DothanSimulator(r0=0.03, mu=0.02, sigma=sigma, T=10, dt=0.01)\n",
        "    paths_dist = sim.simulate_paths(n_paths=10000, seed=42)\n",
        "    final_rates = paths_dist[-1, :]\n",
        "    \n",
        "    ax = axes[idx]\n",
        "    \n",
        "    # Histogram\n",
        "    ax.hist(final_rates, bins=50, density=True, alpha=0.7, color='skyblue', edgecolor='black')\n",
        "    \n",
        "    # Theoretical lognormal\n",
        "    log_ret = np.log(final_rates / 0.03)\n",
        "    theoretical_mean = (0.02 - 0.5 * sigma**2) * 10\n",
        "    theoretical_std = sigma * np.sqrt(10)\n",
        "    \n",
        "    x_range = np.linspace(final_rates.min(), final_rates.max(), 100)\n",
        "    theoretical = scipy_stats.lognorm.pdf(x_range, s=theoretical_std, scale=0.03 * np.exp(theoretical_mean))\n",
        "    ax.plot(x_range, theoretical, 'r-', linewidth=2.5, label='Theoretical Lognormal')\n",
        "    \n",
        "    ax.axvline(final_rates.mean(), color='green', linestyle='--', linewidth=2, label='Simulated Mean')\n",
        "    ax.axvline(np.median(final_rates), color='orange', linestyle='--', linewidth=2, label='Simulated Median')\n",
        "    \n",
        "    ax.set_xlabel('Interest Rate (r₁₀)', fontsize=11, fontweight='bold')\n",
        "    ax.set_ylabel('Density', fontsize=11, fontweight='bold')\n",
        "    ax.set_title(f'σ = {sigma:.2f} ({sigma*100:.0f}%)\\nMean: {final_rates.mean():.4f}, Std: {final_rates.std():.4f}',\n",
        "                fontsize=12, fontweight='bold')\n",
        "    ax.legend(fontsize=10)\n",
        "    ax.grid(True, alpha=0.3, axis='y')\n",
        "\n",
        "fig.suptitle('Final Interest Rate Distributions (at T=10 years)\\nUnder Different Volatility Levels',\n",
        "            fontsize=14, fontweight='bold', y=1.00)\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
