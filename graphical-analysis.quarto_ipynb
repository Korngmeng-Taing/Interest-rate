        "---\n",
        "\n",
        "## 2. Bond Price vs Maturity\n",
        "\n",
        "### Price Curves Under Different Scenarios"
      ],
      "id": "d5df8587"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Ensure BondPricingEngine is available\n",
        "class BondPricingEngine:\n",
        "    \"\"\"Price zero-coupon bonds using simulated interest rate paths\"\"\"\n",
        "    \n",
        "    def __init__(self, dt=0.01):\n",
        "        self.dt = dt\n",
        "    \n",
        "    def price_from_paths(self, paths, maturity):\n",
        "        \"\"\"Price a zero-coupon bond\"\"\"\n",
        "        n_steps = paths.shape[0]\n",
        "        n_paths = paths.shape[1]\n",
        "        \n",
        "        # Convert maturity to step index\n",
        "        maturity_step = int(maturity / self.dt)\n",
        "        \n",
        "        if maturity_step > n_steps:\n",
        "            raise ValueError(f\"Maturity {maturity} exceeds simulation horizon\")\n",
        "        \n",
        "        # Accumulate discount factor for each path\n",
        "        discount_factors = np.zeros(n_paths)\n",
        "        \n",
        "        for i in range(n_paths):\n",
        "            # Sum of interest rates up to maturity\n",
        "            rate_integral = np.sum(paths[:maturity_step, i]) * self.dt\n",
        "            # Discount factor\n",
        "            discount_factors[i] = np.exp(-rate_integral)\n",
        "        \n",
        "        # Compute statistics\n",
        "        bond_price = np.mean(discount_factors)\n",
        "        bond_std = np.std(discount_factors) / np.sqrt(n_paths)\n",
        "        z_critical = 1.96  # 95% confidence\n",
        "        ci_lower = bond_price - z_critical * bond_std\n",
        "        ci_upper = bond_price + z_critical * bond_std\n",
        "        \n",
        "        return {\n",
        "            'price': bond_price,\n",
        "            'std_error': bond_std,\n",
        "            'ci_lower': ci_lower,\n",
        "            'ci_upper': ci_upper,\n",
        "            'relative_error': bond_std / bond_price * 100\n",
        "        }\n",
        "\n",
        "# Create pricer instance\n",
        "pricer = BondPricingEngine(dt=0.01)\n",
        "\n",
        "# Code for pricing curves\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "maturities_fine = np.linspace(0.5, 10, 20)\n",
        "\n",
        "# Generate prices for different scenarios\n",
        "scenarios_params = {\n",
        "    'Baseline (r₀=3%, σ=15%)': {'r0': 0.03, 'sigma': 0.15},\n",
        "    'Low Volatility (σ=10%)': {'r0': 0.03, 'sigma': 0.10},\n",
        "    'High Volatility (σ=20%)': {'r0': 0.03, 'sigma': 0.20},\n",
        "    'High Rates (r₀=5%)': {'r0': 0.05, 'sigma': 0.15},\n",
        "}\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(12, 6))\n",
        "colors = ['#1f77b4', '#2ca02c', '#d62728', '#ff7f0e']\n",
        "\n",
        "for (scenario_name, params), color in zip(scenarios_params.items(), colors):\n",
        "    sim_scenario = DothanSimulator(r0=params['r0'], mu=0.02, sigma=params['sigma'], T=10, dt=0.01)\n",
        "    paths_scenario = sim_scenario.simulate_paths(n_paths=3000, seed=42)\n",
        "    \n",
        "    prices_scenario = []\n",
        "    for T in maturities_fine:\n",
        "        result = pricer.price_from_paths(paths_scenario, T)\n",
        "        prices_scenario.append(result['price'])\n",
        "    \n",
        "    ax.plot(maturities_fine, prices_scenario, 'o-', linewidth=2.5, markersize=5,\n",
        "           label=scenario_name, color=color)\n",
        "\n",
        "ax.axhline(y=1.0, color='black', linestyle='--', alpha=0.5, linewidth=1.5, label='Par Value')\n",
        "ax.set_xlabel('Bond Maturity (years)', fontsize=12, fontweight='bold')\n",
        "ax.set_ylabel('Zero-Coupon Bond Price', fontsize=12, fontweight='bold')\n",
        "ax.set_title('Bond Price Curves: Impact of Rate Level and Volatility', fontsize=14, fontweight='bold')\n",
        "ax.legend(fontsize=11, loc='best')\n",
        "ax.grid(True, alpha=0.3)\n",
        "ax.set_ylim([0.50, 1.05])\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "b470d018",
      "execution_count": null,
      "outputs": []
    },
