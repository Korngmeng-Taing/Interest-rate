    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "\n",
        "## 5. Portfolio Value Distribution\n",
        "\n",
        "### Monte Carlo Distribution of Portfolio Values"
      ],
      "id": "a9582ea6"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| code-fold: true\n",
        "#| code-summary: \"Portfolio value distribution\"\n",
        "\n",
        "# Simulate portfolio values across all paths\n",
        "portfolio_bonds_dict = {\n",
        "    'Bond A (2Y)': (2, 0.30),\n",
        "    'Bond B (5Y)': (5, 0.40),\n",
        "    'Bond C (10Y)': (10, 0.30),\n",
        "}\n",
        "\n",
        "# Use simulated paths to get portfolio values at different points\n",
        "n_paths_analysis = 5000\n",
        "sim_base = DothanSimulator(r0=0.03, mu=0.02, sigma=0.15, T=10, dt=0.01)\n",
        "paths_portfolio = sim_base.simulate_paths(n_paths=n_paths_analysis, seed=42)\n",
        "\n",
        "# For each path, compute portfolio value at end\n",
        "portfolio_values = []\n",
        "individual_bond_values = {'Bond A': [], 'Bond B': [], 'Bond C': []}\n",
        "\n",
        "# Compute accumulated interest path integral for each path\n",
        "for path_idx in range(n_paths_analysis):\n",
        "    rate_integral_2y = np.sum(paths_portfolio[:int(2/0.01), path_idx]) * 0.01\n",
        "    rate_integral_5y = np.sum(paths_portfolio[:int(5/0.01), path_idx]) * 0.01\n",
        "    rate_integral_10y = np.sum(paths_portfolio[:int(10/0.01), path_idx]) * 0.01\n",
        "    \n",
        "    price_2y = np.exp(-rate_integral_2y)\n",
        "    price_5y = np.exp(-rate_integral_5y)\n",
        "    price_10y = np.exp(-rate_integral_10y)\n",
        "    \n",
        "    portfolio_val = price_2y * 0.30 + price_5y * 0.40 + price_10y * 0.30\n",
        "    portfolio_values.append(portfolio_val)\n",
        "    \n",
        "    individual_bond_values['Bond A'].append(price_2y)\n",
        "    individual_bond_values['Bond B'].append(price_5y)\n",
        "    individual_bond_values['Bond C'].append(price_10y)\n",
        "\n",
        "portfolio_values = np.array(portfolio_values)\n",
        "\n",
        "# Visualization\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))\n",
        "\n",
        "# Left: Portfolio value distribution\n",
        "ax1.hist(portfolio_values, bins=50, density=True, alpha=0.7, color='steelblue', edgecolor='black')\n",
        "ax1.axvline(portfolio_values.mean(), color='red', linestyle='--', linewidth=2.5, label=f'Mean: {portfolio_values.mean():.4f}')\n",
        "ax1.axvline(np.percentile(portfolio_values, 5), color='orange', linestyle='--', linewidth=2, label=f'VaR(95%): {np.percentile(portfolio_values, 5):.4f}')\n",
        "ax1.axvline(np.percentile(portfolio_values, 1), color='darkred', linestyle='--', linewidth=2, label=f'VaR(99%): {np.percentile(portfolio_values, 1):.4f}')\n",
        "\n",
        "ax1.set_xlabel('Portfolio Value', fontsize=12, fontweight='bold')\n",
        "ax1.set_ylabel('Density', fontsize=12, fontweight='bold')\n",
        "ax1.set_title('Monte Carlo Distribution of Portfolio Values\\n(5000 simulations, varying interest rate paths)',\n",
        "             fontsize=13, fontweight='bold')\n",
        "ax1.legend(fontsize=11)\n",
        "ax1.grid(True, alpha=0.3, axis='y')\n",
        "\n",
        "# Right: Individual bond price distributions\n",
        "bond_names = ['Bond A (2Y)', 'Bond B (5Y)', 'Bond C (10Y)']\n",
        "colors = ['#1f77b4', '#ff7f0e', '#2ca02c']\n",
        "\n",
        "for bond_name, color in zip(bond_names, colors):\n",
        "    bond_short = bond_name.split('(')[0].strip()\n",
        "    ax2.hist(np.array(individual_bond_values[f'Bond {bond_short.split()[1]}']), \n",
        "            bins=50, alpha=0.5, label=bond_name, color=color, density=True)\n",
        "\n",
        "ax2.set_xlabel('Bond Price', fontsize=12, fontweight='bold')\n",
        "ax2.set_ylabel('Density', fontsize=12, fontweight='bold')\n",
        "ax2.set_title('Distribution of Individual Bond Prices Across Paths',\n",
        "             fontsize=13, fontweight='bold')\n",
        "ax2.legend(fontsize=10)\n",
        "ax2.grid(True, alpha=0.3, axis='y')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Print VaR\n",
        "print(\"Portfolio Value-at-Risk Analysis:\")\n",
        "print(\"-\" * 60)\n",
        "print(f\"Mean Portfolio Value:      {portfolio_values.mean():.4f}\")\n",
        "print(f\"Std Dev:                   {portfolio_values.std():.4f}\")\n",
        "print(f\"Min:                       {portfolio_values.min():.4f}\")\n",
        "print(f\"Max:                       {portfolio_values.max():.4f}\")\n",
        "print(f\"\\nValue-at-Risk (VaR):\")\n",
        "print(f\"  VaR at 95% confidence:   {np.percentile(portfolio_values, 5):.4f}\")\n",
        "print(f\"  VaR at 99% confidence:   {np.percentile(portfolio_values, 1):.4f}\")\n",
        "print(f\"\\nExpected Shortfall (CVaR):\")\n",
        "print(f\"  CVaR at 95% confidence:  {portfolio_values[portfolio_values <= np.percentile(portfolio_values, 5)].mean():.4f}\")"
      ],
      "id": "d56a97e9",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "\n",
        "## 6. Risk Metrics Comparison\n",
        "\n",
        "### Heatmap of Portfolio Loss Across Scenarios"
      ],
      "id": "db6a2476"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| code-fold: true\n",
        "#| code-summary: \"Scenario analysis heatmap\"\n",
        "\n",
        "# Create scenario matrix\n",
        "initial_rates_scenario = np.array([0.02, 0.025, 0.03, 0.035, 0.04, 0.045, 0.05])\n",
        "volatilities_scenario = np.array([0.10, 0.15, 0.20, 0.25, 0.30])\n",
        "\n",
        "# Portfolio loss matrix (relative to baseline r₀=3%, σ=15%)\n",
        "loss_matrix = np.zeros((len(initial_rates_scenario), len(volatilities_scenario)))\n",
        "\n",
        "# Baseline portfolio value (approximate)\n",
        "sim_baseline_scenario = DothanSimulator(r0=0.03, mu=0.02, sigma=0.15, T=10, dt=0.01)\n",
        "paths_baseline_scenario = sim_baseline_scenario.simulate_paths(n_paths=2000, seed=42)\n",
        "base_portfolio_val = np.mean([np.exp(-np.sum(paths_baseline_scenario[:int(2/0.01), i])*0.01)*0.30 +\n",
        "                               np.exp(-np.sum(paths_baseline_scenario[:int(5/0.01), i])*0.01)*0.40 +\n",
        "                               np.exp(-np.sum(paths_baseline_scenario[:int(10/0.01), i])*0.01)*0.30\n",
        "                               for i in range(2000)])\n",
        "\n",
        "for i, r0_scen in enumerate(initial_rates_scenario):\n",
        "    for j, sigma_scen in enumerate(volatilities_scenario):\n",
        "        sim_scen = DothanSimulator(r0=r0_scen, mu=0.02, sigma=sigma_scen, T=10, dt=0.01)\n",
        "        paths_scen = sim_scen.simulate_paths(n_paths=1000, seed=42)\n",
        "        \n",
        "        scen_portfolio_val = np.mean([np.exp(-np.sum(paths_scen[:int(2/0.01), k1])*0.01)*0.30 +\n",
        "                                      np.exp(-np.sum(paths_scen[:int(5/0.01), k1])*0.01)*0.40 +\n",
        "                                      np.exp(-np.sum(paths_scen[:int(10/0.01), k1])*0.01)*0.30\n",
        "                                      for k1 in range(1000)])\n",
        "        \n",
        "        loss_matrix[i, j] = (scen_portfolio_val - base_portfolio_val) / base_portfolio_val * 100\n",
        "\n",
        "# Heatmap\n",
        "fig, ax = plt.subplots(figsize=(11, 7))\n",
        "\n",
        "im = ax.imshow(loss_matrix.T, aspect='auto', origin='lower', cmap='RdYlGn', vmin=-15, vmax=5)\n",
        "\n",
        "ax.set_xticks(range(len(initial_rates_scenario)))\n",
        "ax.set_xticklabels([f'{r:.1%}' for r in initial_rates_scenario], fontsize=10)\n",
        "ax.set_yticks(range(len(volatilities_scenario)))\n",
        "ax.set_yticklabels([f'{v:.2f}' for v in volatilities_scenario], fontsize=10)\n",
        "\n",
        "ax.set_xlabel('Initial Interest Rate (r₀)', fontsize=12, fontweight='bold')\n",
        "ax.set_ylabel('Volatility (σ)', fontsize=12, fontweight='bold')\n",
        "ax.set_title('Portfolio Loss (%) Across Scenarios\\nRelative to Baseline (r₀=3%, σ=15%)',\n",
        "            fontsize=13, fontweight='bold')\n",
        "\n",
        "# Add values to heatmap\n",
        "for i in range(len(initial_rates_scenario)):\n",
        "    for j in range(len(volatilities_scenario)):\n",
        "        text = ax.text(i, j, f'{loss_matrix[i, j]:.1f}%',\n",
        "                      ha=\"center\", va=\"center\", color=\"black\" if abs(loss_matrix[i, j]) < 7 else \"white\",\n",
        "                      fontsize=9, fontweight='bold')\n",
        "\n",
        "cbar = plt.colorbar(im, ax=ax, label='Portfolio Loss (%)')\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "f95b2d56",
      "execution_count": null,
      "outputs": []
    },
