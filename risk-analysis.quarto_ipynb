  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "title: \"Interest Rate Risk Analysis\"\n",
        "author: \"Financial Risk Management\"\n",
        "date: today\n",
        "---\n",
        "\n",
        "## Overview\n",
        "\n",
        "This section performs comprehensive interest rate risk analysis using the Dothan model and simulated bond prices. We execute four key tasks:\n",
        "\n",
        "1. **Impact of Interest Rate Volatility**: Analyze how bond prices change with different volatility levels\n",
        "\n",
        "2. **Initial Interest Rate Changes**: Assess sensitivity to starting rate level\n",
        "\n",
        "3. **Bond Portfolio Risk**: Evaluate risk in a realistic portfolio\n",
        "\n",
        "4. **Interest Rate Shock Scenario**: Stress test under sudden rate increases\n",
        "\n",
        "---\n",
        "\n",
        "## Setup: Initialize Simulator"
      ],
      "id": "171fc2f7"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: setup-risk-analysis\n",
        "#| code-fold: true\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy import stats\n",
        "\n",
        "class DothanSimulator:\n",
        "    \"\"\"Efficient Dothan model interest rate path simulator\"\"\"\n",
        "    \n",
        "    def __init__(self, r0, mu, sigma, T, dt=0.01):\n",
        "        \"\"\"\n",
        "        Initialize the simulator\n",
        "        \n",
        "        Parameters\n",
        "        ----------\n",
        "        r0 : float\n",
        "            Initial short rate (e.g., 0.03 for 3%)\n",
        "        mu : float\n",
        "            Drift parameter (annual, e.g., 0.02 for 2%)\n",
        "        sigma : float\n",
        "            Volatility parameter (annual, e.g., 0.15 for 15%)\n",
        "        T : float\n",
        "            Time horizon in years (e.g., 10)\n",
        "        dt : float\n",
        "            Time step in years (e.g., 0.01 for ~2.5 trading days)\n",
        "        \"\"\"\n",
        "        self.r0 = r0\n",
        "        self.mu = mu\n",
        "        self.sigma = sigma\n",
        "        self.T = T\n",
        "        self.dt = dt\n",
        "        self.n_steps = int(T / dt)\n",
        "        self.time_grid = np.linspace(0, T, self.n_steps)\n",
        "        \n",
        "        # Precompute constants for efficiency\n",
        "        self.drift_coeff = self.mu * self.dt\n",
        "        self.diffusion_coeff = self.sigma * np.sqrt(self.dt)\n",
        "        \n",
        "    def simulate_paths(self, n_paths, seed=None):\n",
        "        \"\"\"\n",
        "        Simulate multiple interest rate paths efficiently\n",
        "        \n",
        "        Parameters\n",
        "        ----------\n",
        "        n_paths : int\n",
        "            Number of paths to simulate (e.g., 10000)\n",
        "        seed : int, optional\n",
        "            Random seed for reproducibility\n",
        "        \n",
        "        Returns\n",
        "        -------\n",
        "        paths : ndarray of shape (n_steps, n_paths)\n",
        "            Simulated interest rate paths\n",
        "        \"\"\"\n",
        "        if seed is not None:\n",
        "            np.random.seed(seed)\n",
        "        \n",
        "        # Initialize array\n",
        "        paths = np.zeros((self.n_steps, n_paths))\n",
        "        paths[0, :] = self.r0\n",
        "        \n",
        "        # Generate all random variables at once (vectorized)\n",
        "        Z = np.random.standard_normal((self.n_steps - 1, n_paths))\n",
        "        \n",
        "        # Simulation loop (vectorized over paths)\n",
        "        for t in range(1, self.n_steps):\n",
        "            drift = self.drift_coeff * paths[t-1, :]\n",
        "            diffusion = self.diffusion_coeff * paths[t-1, :] * Z[t-1, :]\n",
        "            paths[t, :] = paths[t-1, :] + drift + diffusion\n",
        "            \n",
        "            # Optional: enforce positive rates\n",
        "            paths[t, :] = np.maximum(paths[t, :], 1e-8)\n",
        "        \n",
        "        return paths\n",
        "    \n",
        "    def statistics(self, paths):\n",
        "        \"\"\"Compute comprehensive path statistics\"\"\"\n",
        "        stats_dict = {\n",
        "            'mean_path': np.mean(paths, axis=1),\n",
        "            'median_path': np.median(paths, axis=1),\n",
        "            'std_path': np.std(paths, axis=1),\n",
        "            'min_path': np.min(paths, axis=1),\n",
        "            'max_path': np.max(paths, axis=1),\n",
        "            'percentile_05': np.percentile(paths, 5, axis=1),\n",
        "            'percentile_95': np.percentile(paths, 95, axis=1),\n",
        "            'percentile_25': np.percentile(paths, 25, axis=1),\n",
        "            'percentile_75': np.percentile(paths, 75, axis=1),\n",
        "        }\n",
        "        \n",
        "        # Final statistics\n",
        "        final_rates = paths[-1, :]\n",
        "        stats_dict['final_mean'] = np.mean(final_rates)\n",
        "        stats_dict['final_median'] = np.median(final_rates)\n",
        "        stats_dict['final_std'] = np.std(final_rates)\n",
        "        stats_dict['final_min'] = np.min(final_rates)\n",
        "        stats_dict['final_max'] = np.max(final_rates)\n",
        "        \n",
        "        return stats_dict\n",
        "\n",
        "class BondPricingEngine:\n",
        "    \"\"\"Price zero-coupon bonds using simulated interest rate paths\"\"\"\n",
        "    \n",
        "    def __init__(self, dt=0.01):\n",
        "        \"\"\"\n",
        "        Parameters\n",
        "        ----------\n",
        "        dt : float\n",
        "            Time step used in path simulation (must match simulator)\n",
        "        \"\"\"\n",
        "        self.dt = dt\n",
        "    \n",
        "    def price_from_paths(self, paths, maturity):\n",
        "        \"\"\"\n",
        "        Price a zero-coupon bond maturing at 'maturity' \n",
        "        using simulated interest rate paths\n",
        "        \n",
        "        Parameters\n",
        "        ----------\n",
        "        paths : ndarray of shape (n_steps, n_paths)\n",
        "            Simulated interest rate paths\n",
        "        maturity : float\n",
        "            Bond maturity in years\n",
        "        \n",
        "        Returns\n",
        "        -------\n",
        "        bond_price : float\n",
        "            Estimated bond price\n",
        "        bond_std : float\n",
        "            Standard error of estimate\n",
        "        bond_ci : tuple\n",
        "            95% confidence interval (lower, upper)\n",
        "        \"\"\"\n",
        "        n_steps = paths.shape[0]\n",
        "        n_paths = paths.shape[1]\n",
        "        \n",
        "        # Convert maturity to step index\n",
        "        maturity_step = int(maturity / self.dt)\n",
        "        \n",
        "        # Ensure maturity is within simulation horizon\n",
        "        if maturity_step > n_steps:\n",
        "            raise ValueError(f\"Maturity {maturity} exceeds simulation horizon\")\n",
        "        \n",
        "        # Accumulate discount factor for each path\n",
        "        discount_factors = np.zeros(n_paths)\n",
        "        \n",
        "        for i in range(n_paths):\n",
        "            # Sum of interest rates up to maturity\n",
        "            rate_integral = np.sum(paths[:maturity_step, i]) * self.dt\n",
        "            # Discount factor\n",
        "            discount_factors[i] = np.exp(-rate_integral)\n",
        "        \n",
        "        # Compute statistics\n",
        "        bond_price = np.mean(discount_factors)\n",
        "        bond_std = np.std(discount_factors) / np.sqrt(n_paths)\n",
        "        z_critical = 1.96  # 95% confidence\n",
        "        ci_lower = bond_price - z_critical * bond_std\n",
        "        ci_upper = bond_price + z_critical * bond_std\n",
        "        \n",
        "        return {\n",
        "            'price': bond_price,\n",
        "            'std_error': bond_std,\n",
        "            'ci_lower': ci_lower,\n",
        "            'ci_upper': ci_upper,\n",
        "            'relative_error': bond_std / bond_price * 100\n",
        "        }\n",
        "\n",
        "print(\"Simulator and engine initialized.\")\n",
        "\n",
        "# Create pricer instance\n",
        "pricer = BondPricingEngine(dt=0.01)"
      ],
      "id": "setup-risk-analysis",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "\n",
        "## TASK 1: Impact of Interest Rate Volatility\n",
        "\n",
        "### Objective\n",
        "Understand how **uncertainty** in future interest rates affects bond prices. Higher volatility increases uncertainty, which (paradoxically) increases bond prices due to convexity.\n",
        "\n",
        "### Analysis"
      ],
      "id": "3e022027"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: task1-volatility\n",
        "#| code-fold: false\n",
        "\n",
        "# Parameters for volatility study\n",
        "base_params = {'r0': 0.03, 'mu': 0.02, 'T': 10, 'dt': 0.01}\n",
        "volatilities = [0.10, 0.15, 0.20, 0.25, 0.30]\n",
        "maturities = np.array([1, 3, 5, 10])\n",
        "\n",
        "print(\"\\n\" + \"=\"*100)\n",
        "print(\"TASK 1: IMPACT OF INTEREST RATE VOLATILITY\")\n",
        "print(\"=\"*100)\n",
        "\n",
        "# Simulate and price for each volatility\n",
        "results_vol = {}\n",
        "\n",
        "for sigma in volatilities:\n",
        "    # Simulate paths\n",
        "    sim = DothanSimulator(r0=base_params['r0'], mu=base_params['mu'],\n",
        "                          sigma=sigma, T=base_params['T'], dt=base_params['dt'])\n",
        "    paths = sim.simulate_paths(n_paths=5000, seed=42)\n",
        "    \n",
        "    # Price bonds\n",
        "    prices = []\n",
        "    for T in maturities:\n",
        "        result = pricer.price_from_paths(paths, T)\n",
        "        prices.append(result['price'])\n",
        "    \n",
        "    results_vol[sigma] = prices\n",
        "    \n",
        "    # Print results\n",
        "    print(f\"\\nVolatility σ = {sigma:.2f} ({sigma*100:.0f}%):\")\n",
        "    print(\"  Maturity  |  1Y    |  3Y    |  5Y    | 10Y\")\n",
        "    print(\"  \" + \"-\" * 35)\n",
        "    print(f\"  Price     | {prices[0]:.4f} | {prices[1]:.4f} | {prices[2]:.4f} | {prices[3]:.4f}\")\n",
        "\n",
        "# Compare price changes (relative to base volatility)\n",
        "base_vol_prices = results_vol[0.15]\n",
        "print(\"\\n\" + \"=\"*100)\n",
        "print(\"PRICE CHANGES RELATIVE TO BASELINE (σ = 0.15)\")\n",
        "print(\"=\"*100)\n",
        "\n",
        "comparison_df = []\n",
        "for sigma in volatilities:\n",
        "    row = {'Volatility': f'{sigma:.2f}'}\n",
        "    for i, T in enumerate(maturities):\n",
        "        change_pct = (results_vol[sigma][i] - base_vol_prices[i]) / base_vol_prices[i] * 100\n",
        "        row[f'{int(T)}Y'] = f'{change_pct:+.2f}%'\n",
        "    comparison_df.append(row)\n",
        "\n",
        "comp_table = pd.DataFrame(comparison_df)\n",
        "print(comp_table.to_string(index=False))\n",
        "\n",
        "# Visualization 1: Price curves\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))\n",
        "\n",
        "# Left: Bond price vs maturity for different volatilities\n",
        "colors = plt.cm.RdYlGn_r(np.linspace(0, 1, len(volatilities)))\n",
        "for sigma, color in zip(volatilities, colors):\n",
        "    ax1.plot(maturities, results_vol[sigma], 'o-', linewidth=2.5, markersize=7,\n",
        "            label=f'σ = {sigma:.2f}', color=color)\n",
        "\n",
        "ax1.axhline(y=1.0, color='black', linestyle='--', alpha=0.5, linewidth=1, label='Par')\n",
        "ax1.set_xlabel('Bond Maturity (years)', fontsize=12, fontweight='bold')\n",
        "ax1.set_ylabel('Bond Price', fontsize=12, fontweight='bold')\n",
        "ax1.set_title('TASK 1: Bond Prices vs Maturity\\n(varying volatility)',\n",
        "             fontsize=13, fontweight='bold')\n",
        "ax1.legend(fontsize=10, loc='best')\n",
        "ax1.grid(True, alpha=0.3)\n",
        "ax1.set_ylim([0.62, 1.02])\n",
        "\n",
        "# Right: Price sensitivity heatmap\n",
        "volatility_labels = [f'{v:.2f}' for v in volatilities]\n",
        "sensitivity_matrix = np.array([[results_vol[v][i] for i in range(len(maturities))] \n",
        "                               for v in volatilities])\n",
        "\n",
        "im = ax2.imshow(sensitivity_matrix, cmap='RdYlGn', aspect='auto', origin='lower')\n",
        "ax2.set_xticks(range(len(maturities)))\n",
        "ax2.set_xticklabels([f'{int(T)}Y' for T in maturities])\n",
        "ax2.set_yticks(range(len(volatilities)))\n",
        "ax2.set_yticklabels(volatility_labels)\n",
        "ax2.set_xlabel('Bond Maturity', fontsize=12, fontweight='bold')\n",
        "ax2.set_ylabel('Volatility (σ)', fontsize=12, fontweight='bold')\n",
        "ax2.set_title('Bond Price Heatmap', fontsize=13, fontweight='bold')\n",
        "\n",
        "# Add values to heatmap\n",
        "for i in range(len(volatilities)):\n",
        "    for j in range(len(maturities)):\n",
        "        text = ax2.text(j, i, f'{sensitivity_matrix[i, j]:.3f}',\n",
        "                       ha=\"center\", va=\"center\", color=\"black\", fontsize=9, fontweight='bold')\n",
        "\n",
        "plt.colorbar(im, ax=ax2, label='Bond Price')\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\\n✓ INSIGHT: Higher volatility → Higher bond prices (convexity effect)\")\n",
        "print(\"           The effect is stronger for longer maturity bonds\")"
      ],
      "id": "task1-volatility",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "---\n",
        "\n",
        "## TASK 2: Initial Interest Rate Changes\n",
        "\n",
        "### Objective\n",
        "Analyze how the **starting level** of interest rates affects bond prices and their distribution.\n",
        "\n",
        "### Analysis"
      ],
      "id": "e99dd598"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: task2-initial-rate\n",
        "#| code-fold: false\n",
        "\n",
        "# Parameters for initial rate study\n",
        "initial_rates = [0.02, 0.03, 0.04, 0.05]\n",
        "\n",
        "print(\"\\n\" + \"=\"*100)\n",
        "print(\"TASK 2: IMPACT OF INITIAL INTEREST RATE CHANGES\")\n",
        "print(\"=\"*100)\n",
        "\n",
        "# Simulate and price for each initial rate\n",
        "results_r0 = {}\n",
        "\n",
        "for r0 in initial_rates:\n",
        "    sim = DothanSimulator(r0=r0, mu=0.02, sigma=0.15, T=10, dt=0.01)\n",
        "    paths = sim.simulate_paths(n_paths=5000, seed=42)\n",
        "    \n",
        "    prices = []\n",
        "    for T in maturities:\n",
        "        result = pricer.price_from_paths(paths, T)\n",
        "        prices.append(result['price'])\n",
        "    \n",
        "    results_r0[r0] = prices\n",
        "    \n",
        "    print(f\"\\nInitial Rate r₀ = {r0:.1%}:\")\n",
        "    print(\"  Maturity  |  1Y    |  3Y    |  5Y    | 10Y\")\n",
        "    print(\"  \" + \"-\" * 35)\n",
        "    print(f\"  Price     | {prices[0]:.4f} | {prices[1]:.4f} | {prices[2]:.4f} | {prices[3]:.4f}\")\n",
        "\n",
        "# Compare price changes (relative to baseline r₀ = 0.03)\n",
        "base_r0_prices = results_r0[0.03]\n",
        "print(\"\\n\" + \"=\"*100)\n",
        "print(\"PRICE CHANGES RELATIVE TO BASELINE (r₀ = 0.03)\")\n",
        "print(\"=\"*100)\n",
        "\n",
        "comparison_r0_df = []\n",
        "for r0 in initial_rates:\n",
        "    row = {'Initial Rate': f'{r0:.1%}'}\n",
        "    for i, T in enumerate(maturities):\n",
        "        change_pct = (results_r0[r0][i] - base_r0_prices[i]) / base_r0_prices[i] * 100\n",
        "        row[f'{int(T)}Y'] = f'{change_pct:+.2f}%'\n",
        "    comparison_r0_df.append(row)\n",
        "\n",
        "comp_r0_table = pd.DataFrame(comparison_r0_df)\n",
        "print(comp_r0_table.to_string(index=False))\n",
        "\n",
        "# Visualization\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))\n",
        "\n",
        "# Left: Bond price vs maturity for different r₀\n",
        "colors_r0 = plt.cm.coolwarm(np.linspace(0, 1, len(initial_rates)))\n",
        "for r0, color in zip(initial_rates, colors_r0):\n",
        "    ax1.plot(maturities, results_r0[r0], 'o-', linewidth=2.5, markersize=7,\n",
        "            label=f'r₀ = {r0:.1%}', color=color)\n",
        "\n",
        "ax1.axhline(y=1.0, color='black', linestyle='--', alpha=0.5, linewidth=1, label='Par')\n",
        "ax1.set_xlabel('Bond Maturity (years)', fontsize=12, fontweight='bold')\n",
        "ax1.set_ylabel('Bond Price', fontsize=12, fontweight='bold')\n",
        "ax1.set_title('TASK 2: Bond Prices vs Maturity\\n(varying initial rate)',\n",
        "             fontsize=13, fontweight='bold')\n",
        "ax1.legend(fontsize=10, loc='best')\n",
        "ax1.grid(True, alpha=0.3)\n",
        "ax1.set_ylim([0.55, 1.05])\n",
        "\n",
        "# Right: Show price impact bar chart\n",
        "x_pos = np.arange(len(maturities))\n",
        "width = 0.18\n",
        "for i, r0 in enumerate(initial_rates):\n",
        "    offset = (i - 1.5) * width\n",
        "    prices_norm = np.array(results_r0[r0]) / np.array(base_r0_prices) - 1\n",
        "    ax2.bar(x_pos + offset, prices_norm * 100, width, label=f'r₀ = {r0:.1%}', alpha=0.8)\n",
        "\n",
        "ax2.axhline(y=0, color='black', linestyle='-', linewidth=1)\n",
        "ax2.set_ylabel('Price Change vs Baseline (%)', fontsize=12, fontweight='bold')\n",
        "ax2.set_xlabel('Bond Maturity', fontsize=12, fontweight='bold')\n",
        "ax2.set_title('Bond Price Sensitivity to Initial Rate', fontsize=13, fontweight='bold')\n",
        "ax2.set_xticks(x_pos)\n",
        "ax2.set_xticklabels([f'{int(T)}Y' for T in maturities])\n",
        "ax2.legend(fontsize=10)\n",
        "ax2.grid(True, alpha=0.3, axis='y')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\\n✓ INSIGHT: Higher initial rates → Lower bond prices (inverse relationship)\")\n",
        "print(\"           Multiplicative effect: 100bp increase in r₀ → 3-5% price decrease\")"
      ],
      "id": "task2-initial-rate",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
