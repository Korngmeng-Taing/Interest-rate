      "source": [
        "---\n",
        "\n",
        "## TASK 3: Bond Portfolio Risk\n",
        "\n",
        "### Objective\n",
        "Evaluate risk metrics for a realistic multi-bond portfolio and understand diversification benefits.\n",
        "\n",
        "### Analysis"
      ],
      "id": "b36086ce"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: task3-portfolio-risk\n",
        "#| code-fold: false\n",
        "\n",
        "print(\"\\n\" + \"=\"*100)\n",
        "print(\"TASK 3: BOND PORTFOLIO RISK ANALYSIS\")\n",
        "print(\"=\"*100)\n",
        "\n",
        "# Define portfolio\n",
        "portfolio_bonds = {\n",
        "    'Bond A (2Y)': (2, 0.30),\n",
        "    'Bond B (5Y)': (5, 0.40),\n",
        "    'Bond C (10Y)': (10, 0.30)\n",
        "}\n",
        "\n",
        "# Price bonds at baseline (r₀ = 3%)\n",
        "sim_baseline = DothanSimulator(r0=0.03, mu=0.02, sigma=0.15, T=10, dt=0.01)\n",
        "paths_baseline = sim_baseline.simulate_paths(n_paths=10000, seed=42)\n",
        "\n",
        "portfolio_prices = {}\n",
        "bond_details = {}\n",
        "\n",
        "print(\"\\nPortfolio Composition:\")\n",
        "print(\"-\" * 100)\n",
        "print(\"Bond Name         | Maturity | Weight | Current Price | Position Size (1M investment)\")\n",
        "print(\"-\" * 100)\n",
        "\n",
        "total_portfolio_value = 0\n",
        "for bond_name, (maturity, weight) in portfolio_bonds.items():\n",
        "    result = pricer.price_from_paths(paths_baseline, maturity)\n",
        "    bond_price = result['price']\n",
        "    \n",
        "    # Assume $1M total portfolio\n",
        "    position_weight = weight\n",
        "    position_value = 1_000_000 * weight\n",
        "    position_units = position_value / bond_price\n",
        "    \n",
        "    portfolio_prices[bond_name] = bond_price\n",
        "    bond_details[bond_name] = {\n",
        "        'maturity': maturity,\n",
        "        'weight': weight,\n",
        "        'price': bond_price,\n",
        "        'position_value': position_value,\n",
        "        'units': position_units\n",
        "    }\n",
        "    total_portfolio_value += position_value\n",
        "    \n",
        "    print(f\"{bond_name:17} | {maturity:8.0f} | {weight:5.1%} | ${bond_price:13.4f} | \"\n",
        "          f\"${position_value:>12,.0f}\")\n",
        "\n",
        "print(\"-\" * 100)\n",
        "print(f\"{'Total Portfolio Value':36} | ${total_portfolio_value:>12,.0f}\")\n",
        "print(\"-\" * 100)\n",
        "\n",
        "# Compute portfolio metrics\n",
        "print(\"\\nPortfolio Risk Metrics:\")\n",
        "print(\"-\" * 100)\n",
        "\n",
        "# Duration (weighted average)\n",
        "durations = (2, 5, 10)\n",
        "weights = [bd['weight'] for bd in bond_details.values()]\n",
        "portfolio_duration = sum(d * w for d, w in zip(durations, weights))\n",
        "\n",
        "print(f\"Portfolio Duration:        {portfolio_duration:.2f} years\")\n",
        "print(f\"Portfolio Value:           ${total_portfolio_value:,.0f}\")\n",
        "\n",
        "# Compute value changes under different scenarios\n",
        "scenarios = {\n",
        "    'Δr = +0.5%': 0.005,\n",
        "    'Δr = +1.0%': 0.010,\n",
        "    'Δr = +1.5%': 0.015,\n",
        "    'Δr = +2.0%': 0.020,\n",
        "}\n",
        "\n",
        "print(\"\\n\" + \"=\"*100)\n",
        "print(\"SCENARIO ANALYSIS: Bond Price Changes Under Rate Shocks\")\n",
        "print(\"=\"*100)\n",
        "\n",
        "scenario_results = []\n",
        "\n",
        "for scenario_name, rate_shock in scenarios.items():\n",
        "    # Simulate with shifted initial rate\n",
        "    sim_shocked = DothanSimulator(r0=0.03 + rate_shock, mu=0.02, sigma=0.15, T=10, dt=0.01)\n",
        "    paths_shocked = sim_shocked.simulate_paths(n_paths=10000, seed=42)\n",
        "    \n",
        "    portfolio_value_shocked = 0\n",
        "    \n",
        "    for bond_name, (maturity, weight) in portfolio_bonds.items():\n",
        "        result = pricer.price_from_paths(paths_shocked, maturity)\n",
        "        new_price = result['price']\n",
        "        \n",
        "        # New position value\n",
        "        units = bond_details[bond_name]['units']\n",
        "        new_position_value = units * new_price\n",
        "        portfolio_value_shocked += new_position_value\n",
        "    \n",
        "    portfolio_loss = portfolio_value_shocked - total_portfolio_value\n",
        "    portfolio_loss_pct = portfolio_loss / total_portfolio_value * 100\n",
        "    \n",
        "    scenario_results.append({\n",
        "        'Scenario': scenario_name,\n",
        "        'New Portfolio Value': portfolio_value_shocked,\n",
        "        'Loss ($)': portfolio_loss,\n",
        "        'Loss (%)': portfolio_loss_pct\n",
        "    })\n",
        "    \n",
        "    print(f\"\\n{scenario_name}:\")\n",
        "    print(f\"  New portfolio value: ${portfolio_value_shocked:>12,.0f}\")\n",
        "    print(f\"  Portfolio loss:      ${portfolio_loss:>12,.0f} ({portfolio_loss_pct:>6.2f}%)\")\n",
        "\n",
        "# Create visualization\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))\n",
        "\n",
        "# Left: Portfolio composition\n",
        "bond_names = list(portfolio_bonds.keys())\n",
        "weights_list = [portfolio_bonds[bn][1] for bn in bond_names]\n",
        "colors_pie = ['#1f77b4', '#ff7f0e', '#2ca02c']\n",
        "\n",
        "ax1.pie(weights_list, labels=bond_names, autopct='%1.1f%%', colors=colors_pie,\n",
        "        startangle=90, textprops={'fontsize': 11, 'fontweight': 'bold'})\n",
        "ax1.set_title('Portfolio Composition\\n($1M Total)', fontsize=13, fontweight='bold')\n",
        "\n",
        "# Right: Loss under scenarios\n",
        "scenarios_list = [sr['Scenario'] for sr in scenario_results]\n",
        "losses_pct = [sr['Loss (%)'] for sr in scenario_results]\n",
        "losses_dollar = [sr['Loss ($)'] for sr in scenario_results]\n",
        "\n",
        "ax2.bar(range(len(scenarios_list)), losses_dollar, color='#d62728', alpha=0.7, edgecolor='black', linewidth=1.5)\n",
        "ax2.set_ylabel('Portfolio Loss ($)', fontsize=12, fontweight='bold')\n",
        "ax2.set_xlabel('Interest Rate Shock Scenario', fontsize=12, fontweight='bold')\n",
        "ax2.set_title('Portfolio Loss Under Rate Shocks', fontsize=13, fontweight='bold')\n",
        "ax2.set_xticks(range(len(scenarios_list)))\n",
        "ax2.set_xticklabels(scenarios_list, rotation=0, fontsize=10)\n",
        "ax2.grid(True, alpha=0.3, axis='y')\n",
        "\n",
        "# Add value labels\n",
        "for i, (loss_dollar, loss_pct) in enumerate(zip(losses_dollar, losses_pct)):\n",
        "    ax2.text(i, loss_dollar - 5000, f'${loss_dollar/1000:.0f}K\\n({loss_pct:.2f}%)', \n",
        "            ha='center', va='top', fontsize=10, fontweight='bold')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\\n✓ INSIGHT: Portfolio duration = {:.2f} years\".format(portfolio_duration))\n",
        "print(\"           1% rate shock → ~{:.1f}% portfolio loss (approximation)\".format(portfolio_duration))"
      ],
