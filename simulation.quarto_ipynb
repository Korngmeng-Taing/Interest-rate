      "source": [
        "---\n",
        "\n",
        "## Validation of Simulation\n",
        "\n",
        "### Check 1: Verify Lognormality\n",
        "\n",
        "Under the Dothan model, log-returns should be normally distributed:"
      ],
      "id": "7fbc924b"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| code-fold: true\n",
        "#| code-summary: \"Validate lognormality\"\n",
        "\n",
        "import numpy as np\n",
        "from scipy import stats\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# From simulated paths\n",
        "final_rates = paths[-1, :]\n",
        "log_returns = np.log(final_rates / 0.03)  # log(r_T / r_0)\n",
        "\n",
        "# Expected theoretical distribution\n",
        "expected_mean = (0.02 - 0.5 * 0.15**2) * 10\n",
        "expected_std = 0.15 * np.sqrt(10)\n",
        "\n",
        "# K-S test\n",
        "ks_stat, pvalue = stats.kstest(log_returns, 'norm', args=(expected_mean, expected_std))\n",
        "\n",
        "print(f\"\\nLognormality Test (Kolmogorov-Smirnov):\")\n",
        "print(f\"  KS Statistic: {ks_stat:.4f}\")\n",
        "print(f\"  p-value: {pvalue:.4f}\")\n",
        "print(f\"  Result: {'✓ PASS' if pvalue > 0.05 else '✗ FAIL'} (fail if p < 0.05)\")\n",
        "\n",
        "# Visual check\n",
        "fig, ax = plt.subplots(figsize=(10, 6))\n",
        "\n",
        "# Histogram of log-returns\n",
        "ax.hist(log_returns, bins=50, density=True, alpha=0.7, label='Simulated', color='skyblue')\n",
        "\n",
        "# Theoretical normal distribution\n",
        "x = np.linspace(log_returns.min(), log_returns.max(), 100)\n",
        "theoretical = stats.norm.pdf(x, expected_mean, expected_std)\n",
        "ax.plot(x, theoretical, 'r-', linewidth=2.5, label='Theoretical Normal')\n",
        "\n",
        "ax.set_xlabel('Log-return [log(r_T/r_0)]', fontsize=12, fontweight='bold')\n",
        "ax.set_ylabel('Density', fontsize=12, fontweight='bold')\n",
        "ax.set_title('Validation: Log-returns Should Be Normal\\n(Dothan Model)', \n",
        "             fontsize=13, fontweight='bold')\n",
        "ax.legend(fontsize=11)\n",
        "ax.grid(True, alpha=0.3)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "03260d2f",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Check 2: Verify Moments\n",
        "\n",
        "Compare simulated moments with theoretical:"
      ],
      "id": "68873537"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| code-fold: true\n",
        "#| code-summary: \"Compare simulated vs theoretical moments\"\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "T = 10\n",
        "r0 = 0.03\n",
        "mu = 0.02\n",
        "sigma = 0.15\n",
        "\n",
        "# Theoretical moments (from the analytical solution)\n",
        "E_rT = r0 * np.exp(mu * T)\n",
        "Var_rT = r0**2 * np.exp(2 * mu * T) * (np.exp(sigma**2 * T) - 1)\n",
        "Std_rT = np.sqrt(Var_rT)\n",
        "\n",
        "# Simulated moments\n",
        "simulated_mean = final_rates.mean()\n",
        "simulated_std = final_rates.std()\n",
        "\n",
        "comparison = pd.DataFrame({\n",
        "    'Metric': ['Mean (μ)', 'Std Dev (σ)'],\n",
        "    'Theoretical': [E_rT, Std_rT],\n",
        "    'Simulated': [simulated_mean, simulated_std],\n",
        "    'Error %': [abs(simulated_mean - E_rT) / E_rT * 100,\n",
        "                abs(simulated_std - Std_rT) / Std_rT * 100]\n",
        "})\n",
        "\n",
        "print(\"\\n Moment Validation:\")\n",
        "print(comparison.to_string(index=False))"
      ],
      "id": "ef504e6d",
      "execution_count": null,
      "outputs": []
    },
