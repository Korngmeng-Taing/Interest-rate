        "---\n",
        "\n",
        "## Parameter Sensitivity Studies\n",
        "\n",
        "### Effect of Volatility\n",
        "\n",
        "Vary $\\sigma$ and observe impact on final rate distribution:"
      ],
      "id": "a0dd236c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| code-fold: true\n",
        "#| code-summary: \"Volatility sensitivity\"\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "volatilities = [0.05, 0.10, 0.15, 0.20, 0.30]\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
        "\n",
        "# Left: Paths for different volatilities\n",
        "for sigma_val in volatilities:\n",
        "    sim = DothanSimulator(r0=0.03, mu=0.02, sigma=sigma_val, T=10, dt=0.01)\n",
        "    paths_vol = sim.simulate_paths(n_paths=500, seed=42)\n",
        "    stats_vol = sim.statistics(paths_vol)\n",
        "    axes[0].plot(sim.time_grid, stats_vol['mean_path'], linewidth=2.5, \n",
        "                 label=f'σ={sigma_val:.2f}')\n",
        "\n",
        "axes[0].set_xlabel('Time (years)', fontsize=11, fontweight='bold')\n",
        "axes[0].set_ylabel('Mean Interest Rate', fontsize=11, fontweight='bold')\n",
        "axes[0].set_title('Mean Rate Path (Effect of Volatility)', fontsize=12, fontweight='bold')\n",
        "axes[0].legend()\n",
        "axes[0].grid(True, alpha=0.3)\n",
        "\n",
        "# Right: Final rate distributions\n",
        "for sigma_val in volatilities:\n",
        "    sim = DothanSimulator(r0=0.03, mu=0.02, sigma=sigma_val, T=10, dt=0.01)\n",
        "    paths_vol = sim.simulate_paths(n_paths=5000, seed=42)\n",
        "    axes[1].hist(paths_vol[-1, :], bins=50, alpha=0.5, density=True, \n",
        "                label=f'σ={sigma_val:.2f}')\n",
